# ============================================================
# QueryDen website — environment variables
# ============================================================
#
# This file is a template. Copy to `.env` for local overrides
# (gitignored) or set these in the Vercel project dashboard for
# deployed environments.
#
# The website builds without any of these set — defaults are
# tuned for local development.
#
# ------------------------------------------------------------
# Build-time data fetches
# ------------------------------------------------------------
#
# The site fetches release metadata (version, date, asset names
# + sizes) and the GitHub star count from the public GitHub API
# at build time. These vars control how strict that fetch is.
#
# See website/src/lib/site.ts for the full logic.

# Fail the build if the GitHub releases/latest fetch fails for
# any reason (network error, HTTP 4xx/5xx, malformed JSON,
# missing fields, no installer assets classified).
#
# WHY: prevents Vercel from deploying a build that silently fell
# back to the hardcoded RELEASE_FALLBACK snapshot in site.ts —
# which would show stale version info to users.
#
# WHERE TO SET:
#   - Vercel → Settings → Environment Variables → Production: 1
#   - Do NOT set in Preview/Development (offline builds break)
QUERYDEN_REQUIRE_LIVE_RELEASE=

# Skip the GitHub releases/latest fetch entirely and use the
# hardcoded RELEASE_FALLBACK snapshot in site.ts. Mutually
# exclusive with QUERYDEN_REQUIRE_LIVE_RELEASE.
#
# WHY: reproducible offline builds, or working without network.
#
# Set to "1" to skip.
QUERYDEN_SKIP_GH_RELEASE=

# Skip the GitHub star-count fetch. The star badge in the nav
# will be hidden. Non-fatal regardless of strict-release mode —
# the star count is purely cosmetic.
#
# Set to "1" to skip.
QUERYDEN_SKIP_GH_STARS=
