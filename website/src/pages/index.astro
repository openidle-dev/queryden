---
import Layout from '../layouts/Layout.astro';
import SignatureMesh from '../components/SignatureMesh.astro';
import { SITE, RELEASE, ANNOUNCEMENT, downloadUrl } from '../lib/site';

const version = `v${SITE.version}`;

// Compare table — single source of truth for the comparison section.
const COMPETITORS = [
  { name: 'QueryDen',         sub: 'open · MIT · Tauri',         ours: true  },
  { name: 'DBeaver CE',       sub: 'open · Apache · Eclipse',    ours: false },
  { name: 'TablePlus',        sub: 'commercial · native',        ours: false },
  { name: 'DataGrip',         sub: 'commercial · JetBrains',     ours: false },
  { name: 'Beekeeper Studio', sub: 'open · MIT · Electron',      ours: false },
  { name: 'pgAdmin',          sub: 'open · PostgreSQL · web',    ours: false },
];

// `wedge: true` flags a row as a QueryDen-only or near-only win — shown when the
// table is filtered to "wins only". Rows like SSH tunneling or 'Local history' are
// commodities every tool has and get hidden in that mode.
const ROWS: Array<{ label: string; values: Array<string | boolean>; wedge: boolean }> = [
  { label: 'Engines supported',              values: ['6 (PG · MySQL · Maria · SQLite · Cockroach · Supabase)', '90+ (incl. NoSQL)', '20+', '15+ (relational)', '10+', 'PostgreSQL only'], wedge: false },
  { label: 'Native (no Chromium bundled)',   values: [true, false, true, false, false, false],          wedge: true  },
  { label: 'Installer size',                 values: ['~11 MB', '~250 MB', '~50 MB', '~700 MB', '~200 MB', '~200 MB'], wedge: true },
  { label: 'Machine-locked vault',           values: [true, false, false, false, false, false],         wedge: true  },
  { label: 'Brute-force lockout',            values: [true, false, false, false, false, false],         wedge: true  },
  { label: 'Local history · diffs',          values: [true, 'Yes', 'Yes', 'Yes', 'Yes', 'Limited'],     wedge: false },
  { label: 'Integrated psql · per-version',  values: [true, false, false, false, false, 'bundled'],     wedge: true  },
  { label: 'AI assistant · BYO key',         values: ['OpenAI · Anthropic · Google · Ollama', 'Yes (paid)', false, 'Paid', 'Yes (BYO)', false], wedge: true },
  { label: 'Visual EXPLAIN ANALYZE',         values: [true, 'Yes', false, 'Yes', 'Yes', 'Yes'],         wedge: false },
  { label: 'SSH tunneling',                  values: [true, true, true, true, true, true],              wedge: false },
  { label: 'Telemetry',                      values: ['Zero', 'Opt-out', 'Crash reports', 'Opt-out', 'Opt-out', 'None'], wedge: true },
  { label: 'Price (1 seat)',                 values: ['Free', 'Free', '$89 one-time', '$229/yr', 'Free / $19', 'Free'], wedge: false },
  { label: 'License',                        values: ['MIT', 'Apache 2.0', 'Commercial', 'Commercial', 'MIT (community)', 'PostgreSQL'], wedge: false },
];
const WEDGE_COUNT = ROWS.filter(r => r.wedge).length;

// JSON-LD: SoftwareApplication schema. Tells Google this is a downloadable
// app, what platforms it runs on, that it's free, and where to find it. Drives
// rich-snippet eligibility for app-category searches.
const softwareJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: SITE.name,
  applicationCategory: 'DeveloperApplication',
  applicationSubCategory: 'DatabaseManagement',
  operatingSystem: 'macOS, Windows, Linux',
  url: SITE.homepage,
  downloadUrl: `${SITE.homepage}/download`,
  softwareVersion: SITE.version,
  license: 'https://opensource.org/licenses/MIT',
  description: "A native, open-source SQL client for Postgres, MySQL, SQLite, CockroachDB and Supabase. ~11 MB installer. Built in Rust. Zero app telemetry.",
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  publisher: {
    '@type': 'Organization',
    name: 'OpenIdle',
    url: 'https://openidle.com',
  },
};

// Bento feature tiles. The first (Cmd+K) is the interactive showpiece — keystrokes
// drive the right pane via fuzzy-matched command names. The other five are static
// visual demonstrations of specific features the desktop app actually ships.
const BENTO_KEYBOARD = [
  { keys: ['Ctrl', 'Enter'],      label: 'Run statement under cursor' },
  { keys: ['Ctrl', 'Click'],      label: 'Jump to definition' },
  { keys: ['Alt', 'Enter'],       label: 'Intention actions' },
  { keys: ['Ctrl', 'Shift', 'F'], label: 'Format SQL (in editor)' },
  { keys: ['Cmd', 'K'],           label: 'Command palette' },
];

// Installer-size strip — bars are proportional to MB at a constant 180 MB/s rate,
// so the chart unfolds in roughly the time the download would actually take.
const FOOTPRINT = [
  { name: 'QueryDen',     stack: 'Tauri · Rust',     mb: 11,  size: '~11 MB',  ours: true  },
  { name: 'TablePlus',    stack: 'native',           mb: 50,  size: '~50 MB',  ours: false },
  { name: 'pgAdmin 4',    stack: 'Python · web',     mb: 200, size: '~200 MB', ours: false },
  { name: 'Beekeeper',    stack: 'Electron',         mb: 200, size: '~200 MB', ours: false },
  { name: 'DBeaver CE',   stack: 'Eclipse · JVM',    mb: 250, size: '~250 MB', ours: false },
  { name: 'DataGrip',     stack: 'JetBrains · JVM',  mb: 700, size: '~700 MB', ours: false },
];

---
<Layout
  title="QueryDen — The database manager that isn't an Electron app."
  description="A native, open-source SQL client for Postgres, MySQL, SQLite, CockroachDB and Supabase. 8 MB installer. Built in Rust. Zero app telemetry."
  active="product"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(softwareJsonLd)}></script>

  <!-- ============== HERO ============== -->
  <section class="hero">
    <SignatureMesh intensity="hero" maskFalloff="soft" />
    <div class="wrap hero-inner">
      {ANNOUNCEMENT ? (
        <a class="reveal tag hero-pill hero-pill-link" href={ANNOUNCEMENT.href}>
          <span class="dot"></span>
          <span class="hero-pill-label">{ANNOUNCEMENT.label}</span>
          <span class="hero-pill-sep" aria-hidden="true">·</span>
          <span class="hero-pill-detail">{ANNOUNCEMENT.detail}</span>
          <span class="hero-pill-arrow" aria-hidden="true">→</span>
        </a>
      ) : (
        <div class="reveal tag hero-pill"><span class="dot"></span> {version} · macOS · Windows · Linux</div>
      )}

      <h1 class="display reveal reveal-1">
        The database manager<br/>
        <span class="hero-em">that isn't an Electron app.</span>
      </h1>

      <p class="lede-lg reveal reveal-2 hero-lede">
        A native, open-source SQL client for Postgres, MySQL, SQLite, CockroachDB and Supabase.
        Built in Rust. <span style="color: var(--ink-0);">An 11&nbsp;MB installer</span> — not a
        250&nbsp;MB Java IDE, not a 200&nbsp;MB Chromium bundle pretending to be an app.
      </p>

      <div class="reveal reveal-3 hero-cta">
        <a class="btn btn-lg btn-accent" href="/download" data-cta="hero-download">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12"/><path d="m7 10 5 5 5-5"/><path d="M5 21h14"/></svg>
          <span data-os-cta>Download QueryDen</span>
        </a>
        <a class="btn btn-lg btn-ghost" href={SITE.repo} rel="noopener">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.5 2 2 6.6 2 12.2c0 4.5 2.9 8.3 6.8 9.6.5.1.7-.2.7-.5v-1.8c-2.8.6-3.4-1.2-3.4-1.2-.4-1-1.1-1.3-1.1-1.3-.9-.6.1-.6.1-.6 1 .1 1.6 1 1.6 1 .9 1.6 2.4 1.1 3 .9.1-.7.4-1.2.6-1.4-2.2-.3-4.6-1.1-4.6-5 0-1.1.4-2 1-2.7-.1-.3-.4-1.3.1-2.7 0 0 .8-.3 2.7 1 .8-.2 1.6-.3 2.5-.3.8 0 1.7.1 2.5.3 1.9-1.3 2.7-1 2.7-1 .5 1.4.2 2.4.1 2.7.6.7 1 1.6 1 2.7 0 3.9-2.3 4.7-4.6 5 .4.3.7.9.7 1.9v2.8c0 .3.2.6.7.5 4-1.3 6.8-5.1 6.8-9.6C22 6.6 17.5 2 12 2z"/></svg>
          Star on GitHub
        </a>
      </div>

      <div class="reveal hero-demo" id="hero-demo" aria-hidden="true">
        <div class="hd-frame">
          <div class="hd-chrome">
            <div class="hd-lights" aria-hidden="true">
              <span class="hd-light hd-light-r"></span>
              <span class="hd-light hd-light-y"></span>
              <span class="hd-light hd-light-g"></span>
            </div>
            <span class="hd-tab mono">
              <span class="hd-tab-dot"></span>
              production.acme.dev
              <span class="hd-tab-meta">· postgres 16</span>
            </span>
            <span class="hd-run mono"><kbd>⌘</kbd><kbd>↵</kbd> run</span>
          </div>
          <div class="hd-body">
            <div class="hd-editor">
              <pre class="hd-code mono"><span class="hd-gut">1</span><span class="hd-row" id="hd-row-1"></span>
<span class="hd-gut">2</span><span class="hd-row" id="hd-row-2"></span>
<span class="hd-gut">3</span><span class="hd-row" id="hd-row-3"></span>
<span class="hd-gut">4</span><span class="hd-row" id="hd-row-4"></span></pre>
            </div>
            <div class="hd-result mono" id="hd-result">
              <div class="hd-result-head">
                <span class="hd-r-col">customer</span>
                <span class="hd-r-col">orders</span>
                <span class="hd-r-col">total</span>
              </div>
              <div class="hd-result-row">
                <span>alice@acme.dev</span><span>148</span><span class="hd-r-num">$48,212.40</span>
              </div>
              <div class="hd-result-row">
                <span>renee@acme.dev</span><span>132</span><span class="hd-r-num">$41,008.10</span>
              </div>
              <div class="hd-result-row">
                <span>june@acme.dev</span><span>119</span><span class="hd-r-num">$38,664.55</span>
              </div>
            </div>
          </div>
          <div class="hd-foot mono">
            <span class="hd-ok">●</span> <span id="hd-status">3 rows · 14&nbsp;ms · cached plan</span>
            <span class="hd-side">Ctrl+Click <em>customer</em> → jump to definition</span>
          </div>
        </div>
      </div>

      <p class="reveal hero-foot mono">
        Apple Silicon · Windows x86_64 · Linux x86_64 &nbsp;·&nbsp; MIT licensed &nbsp;·&nbsp; zero app telemetry
      </p>
    </div>
  </section>

  <!-- ============== FOOTPRINT (installer-size, to scale) ============== -->
  <section class="footprint" id="footprint">
    <div class="wrap">
      <div class="reveal section-head footprint-head">
        <div>
          <div class="eyebrow">Footprint · to scale</div>
          <h2 class="footprint-h">
            The other <span class="fp-num">689</span> megabytes<br/>
            <span class="fp-em">weren't doing anything.</span>
          </h2>
        </div>
        <p class="lede">
          Same six engines, same SSH tunneling, same visual EXPLAIN viewer. Minus the
          250&nbsp;MB Chromium runtime everyone else ships. The bars below are real
          installer sizes — drawn at a constant
          <strong style="color: var(--ink-0); font-weight: 500;">180&nbsp;MB/s</strong>,
          so the chart unfolds in roughly the time the downloads would actually take.
        </p>
      </div>

      <div class="reveal footprint-chart" aria-label="Installer size comparison, drawn to scale">
        {FOOTPRINT.map((f) => (
          <div class={`fp-row${f.ours ? ' fp-row-ours' : ''}`} style={`--mb:${f.mb}`}>
            <div class="fp-name">
              <span class="fp-app">{f.name}</span>
              <span class="fp-stack mono">{f.stack}</span>
            </div>
            <div class="fp-track">
              <div class={`fp-bar${f.ours ? ' fp-ours' : ''}`}>
                <span class="fp-size mono" aria-hidden="true">{f.size}</span>
              </div>
              <span class="sr-only">{f.size}</span>
            </div>
          </div>
        ))}
        <div class="fp-axis mono" aria-hidden="true">
          <div class="fp-axis-spacer"></div>
          <div class="fp-axis-ticks">
            <span>0</span><span>175</span><span>350</span><span>525</span><span>700&nbsp;MB</span>
          </div>
        </div>
      </div>

      <p class="reveal fp-foot mono">
        Sizes verified against each project's public installer pages. The cyan bar is
        the entire QueryDen app — drivers, vault, SSH, EXPLAIN viewer, AI assistant.
        <a href="/#compare" class="fp-foot-link">See the full comparison →</a>
      </p>
    </div>
  </section>

  <!-- ============== BENTO (features) ============== -->
  <section class="bento-section" id="features">
    <div class="wrap">
      <div class="reveal section-head bento-head">
        <div>
          <div class="eyebrow">Inside the small one</div>
          <h2 style="margin-top: 14px;">
            Everything is <span class="bento-em">a keystroke</span>.
          </h2>
        </div>
        <p class="lede">
          The 11&nbsp;MB isn't a stripped-down toy. It's six engines, a schema-aware editor, a
          plan-tree viewer, an AI optimizer, parallel multi-DB query, line-level history, a real
          SSH stack — all reachable from one palette and one editor. Try the palette below.
        </p>
      </div>

      <div class="reveal bento">

        <!-- ============== Tile 1 — Command palette (interactive) ============== -->
        <div class="bento-tile bento-cmd" id="bcmd">
          <div class="bcmd-left">
            <div class="bcmd-inputbar">
              <span class="bcmd-prompt mono">⌘K</span>
              <input
                class="bcmd-input mono"
                type="text"
                value="explain"
                spellcheck="false"
                autocomplete="off"
                aria-label="Try the command palette"
              />
              <span class="bcmd-caret" aria-hidden="true"></span>
            </div>
            <div class="bcmd-list" role="listbox" aria-label="Matched commands">
              <button type="button" class="bcmd-item is-active" data-cmd="explain" role="option">
                <span class="bcmd-i-icon">⌥</span>
                <span class="bcmd-i-name">Explain ANALYZE this query</span>
                <span class="bcmd-i-kbd mono">⏎</span>
              </button>
              <button type="button" class="bcmd-item" data-cmd="ai" role="option">
                <span class="bcmd-i-icon">✦</span>
                <span class="bcmd-i-name">Ask AI: optimize this query</span>
                <span class="bcmd-i-kbd mono">⏎</span>
              </button>
              <button type="button" class="bcmd-item" data-cmd="join" role="option">
                <span class="bcmd-i-icon">⇋</span>
                <span class="bcmd-i-name">Insert FK-aware JOIN…</span>
                <span class="bcmd-i-kbd mono">⏎</span>
              </button>
              <button type="button" class="bcmd-item" data-cmd="compare" role="option">
                <span class="bcmd-i-icon">⇆</span>
                <span class="bcmd-i-name">Compare schemas across connections</span>
                <span class="bcmd-i-kbd mono">⏎</span>
              </button>
              <button type="button" class="bcmd-item" data-cmd="history" role="option">
                <span class="bcmd-i-icon">↶</span>
                <span class="bcmd-i-name">Local history for this tab</span>
                <span class="bcmd-i-kbd mono">⏎</span>
              </button>
              <button type="button" class="bcmd-item" data-cmd="mask" role="option">
                <span class="bcmd-i-icon">◐</span>
                <span class="bcmd-i-name">Toggle mask for screenshots</span>
                <span class="bcmd-i-kbd mono">⏎</span>
              </button>
            </div>
            <div class="bcmd-hint mono">
              <span>type to switch · click an item</span>
              <span class="bcmd-hint-keys"><kbd>⏎</kbd> in-app: runs the command</span>
            </div>
          </div>
          <div class="bcmd-right">
            <!-- explain pane -->
            <div class="bcmd-pane bcmd-pane-explain is-active" data-pane="explain">
              <div class="bcmd-pane-head mono">EXPLAIN ANALYZE · plan tree · sorted by cost</div>
              <div class="explain-tree">
                <div class="ex-row ex-d0">
                  <div class="ex-bar"><div class="ex-bar-fill" style="--p: 100%"></div></div>
                  <div class="ex-op">Hash Join</div>
                  <div class="ex-cost mono">312</div>
                </div>
                <div class="ex-row ex-d1 ex-hot">
                  <div class="ex-bar"><div class="ex-bar-fill ex-bar-hot" style="--p: 96%"></div></div>
                  <div class="ex-op">Seq Scan <span class="ex-rel">· orders</span></div>
                  <div class="ex-cost mono">298 <span class="ex-pct">96%</span></div>
                </div>
                <div class="ex-row ex-d2 ex-hint">
                  <div class="ex-bar"><div class="ex-bar-fill" style="--p: 0%"></div></div>
                  <div class="ex-op">Filter <span class="ex-rel mono">customer_email = $1</span></div>
                  <div class="ex-cost mono">no idx</div>
                </div>
                <div class="ex-row ex-d1">
                  <div class="ex-bar"><div class="ex-bar-fill" style="--p: 4%"></div></div>
                  <div class="ex-op">Index Scan <span class="ex-rel">· users_pkey</span></div>
                  <div class="ex-cost mono">12</div>
                </div>
              </div>
              <div class="bcmd-pane-foot mono">
                <span class="ex-flag-dot"></span>
                hot path · click to see suggested index
              </div>
            </div>

            <!-- ai pane -->
            <div class="bcmd-pane bcmd-pane-ai" data-pane="ai">
              <div class="bcmd-pane-head mono">AI · OpenAI / Anthropic / Gemini / Ollama · BYO key</div>
              <pre class="ai-suggest mono"><span class="ai-cur"></span></pre>
              <div class="bcmd-pane-foot mono">
                runs locally · key stays on disk · no telemetry
              </div>
            </div>

            <!-- join pane -->
            <div class="bcmd-pane bcmd-pane-join" data-pane="join">
              <div class="bcmd-pane-head mono">Schema-aware autocomplete · FK graph</div>
              <pre class="join-snippet mono"><span class="jk">SELECT</span> <span class="jc">*</span>
<span class="jk">FROM</span>   users <span class="ja">u</span>
<span class="jk">JOIN</span>   orders <span class="ja">o</span>
<span class="jk">ON</span>     <span class="join-cursor"></span></pre>
              <div class="join-pop">
                <div class="jp-item is-active">
                  <span class="jp-name mono">u.id = o.user_id</span>
                  <span class="jp-tag mono">fk · orders_user_id_fkey</span>
                </div>
                <div class="jp-item">
                  <span class="jp-name mono">u.email = o.customer_email</span>
                  <span class="jp-tag mono">exact match</span>
                </div>
                <div class="jp-item">
                  <span class="jp-name mono">u.organization_id = o.org_id</span>
                  <span class="jp-tag mono">name match</span>
                </div>
              </div>
              <div class="bcmd-pane-foot mono">knows your aliases · knows your foreign keys</div>
            </div>

            <!-- compare pane -->
            <div class="bcmd-pane bcmd-pane-compare" data-pane="compare">
              <div class="bcmd-pane-head mono">Compare · prod ↔ staging</div>
              <div class="cmp-grid">
                <div class="cmp-side">
                  <div class="cmp-label mono">prod.users</div>
                  <ul class="cmp-cols mono">
                    <li>id <span class="cmp-t">uuid</span></li>
                    <li>email <span class="cmp-t">text</span></li>
                    <li>created_at <span class="cmp-t">timestamptz</span></li>
                  </ul>
                </div>
                <div class="cmp-side">
                  <div class="cmp-label mono">staging.users</div>
                  <ul class="cmp-cols mono">
                    <li>id <span class="cmp-t">uuid</span></li>
                    <li>email <span class="cmp-t">text</span></li>
                    <li class="cmp-add">+ email_verified <span class="cmp-t">bool</span></li>
                    <li class="cmp-add">+ verified_at <span class="cmp-t">timestamptz</span></li>
                    <li>created_at <span class="cmp-t">timestamptz</span></li>
                  </ul>
                </div>
              </div>
              <div class="bcmd-pane-foot mono">2 added columns · run the migration on prod →</div>
            </div>

            <!-- history pane -->
            <div class="bcmd-pane bcmd-pane-history" data-pane="history">
              <div class="bcmd-pane-head mono">Local history · 5-second snapshots · this tab</div>
              <div class="hist-diff mono">
                <div class="hist-line hist-rm">- <span>WHERE id = 42</span></div>
                <div class="hist-line hist-ad">+ <span>WHERE customer_id = 42</span></div>
                <div class="hist-line">  ORDER BY created_at DESC</div>
                <div class="hist-line">  LIMIT 100</div>
              </div>
              <div class="bcmd-pane-foot mono">
                <span>8 snapshots · 14 minutes ago</span>
                <button type="button" class="hist-revert mono" tabindex="-1">↶ revert</button>
              </div>
            </div>

            <!-- mask pane -->
            <div class="bcmd-pane bcmd-pane-mask" data-pane="mask">
              <div class="bcmd-pane-head mono">Mask · safe for screensharing</div>
              <table class="mask-grid mono">
                <thead>
                  <tr><th>id</th><th>email</th><th>org</th><th>verified</th></tr>
                </thead>
                <tbody>
                  <tr><td>1</td><td class="mask-cell">••••••@••••••.dev</td><td class="mask-cell">••••••</td><td>true</td></tr>
                  <tr><td>2</td><td class="mask-cell">•••@•••••.com</td><td class="mask-cell">••••••</td><td>true</td></tr>
                  <tr><td>3</td><td class="mask-cell">••••••••@•••.io</td><td class="mask-cell">••••••••</td><td>false</td></tr>
                </tbody>
              </table>
              <div class="bcmd-pane-foot mono">cell mask is per-column · keymap-toggleable</div>
            </div>
          </div>
        </div>

        <!-- ============== Tile 2 — Statement-aware Ctrl+Enter ============== -->
        <div class="bento-tile bento-stmt">
          <div class="b-eye mono">Ctrl + Enter</div>
          <h3 class="b-title">Runs only the<br/>statement you mean.</h3>
          <div class="stmt-buf mono">
            <div class="stmt-line">SELECT count(*) FROM users;</div>
            <div class="stmt-line stmt-active">
              <span class="stmt-bar" aria-hidden="true"></span>
              SELECT * FROM orders WHERE total &gt; 1000<span class="stmt-cursor" aria-hidden="true"></span>
            </div>
            <div class="stmt-line">DELETE FROM cart WHERE expires_at &lt; now();</div>
          </div>
          <p class="b-cap">Parse-aware. Cursor decides what runs — not the file.</p>
        </div>

        <!-- ============== Tile 3 — Local history ============== -->
        <div class="bento-tile bento-hist">
          <div class="b-eye mono">Safety net</div>
          <h3 class="b-title">Every five seconds.<br/>Forever.</h3>
          <div class="hist-mini mono">
            <div class="hm-row"><span class="hm-t">14:32</span> <span>WHERE id = 42</span></div>
            <div class="hm-row hm-active"><span class="hm-t">14:33</span> <span>WHERE customer_id = 42</span></div>
            <div class="hm-row"><span class="hm-t">14:38</span> <span>WHERE customer_id IN (…)</span></div>
            <div class="hm-row"><span class="hm-t">14:46</span> <span>WITH recent AS (…)</span></div>
          </div>
          <p class="b-cap">Silent line-level snapshots of every tab. Locally — never leaves your laptop.</p>
        </div>

        <!-- ============== Tile 4 — Multi-DB fan-out ============== -->
        <div class="bento-tile bento-fan">
          <div class="b-eye mono">Parallel</div>
          <h3 class="b-title">One query.<br/>Many databases.</h3>
          <div class="fan-viz" aria-hidden="true">
            <div class="fan-q mono">SELECT count(*) FROM users;</div>
            <div class="fan-lines">
              <div class="fan-line"></div>
              <div class="fan-line"></div>
              <div class="fan-line"></div>
              <div class="fan-line"></div>
            </div>
            <div class="fan-targets mono">
              <span>prod-eu</span><span>prod-us</span><span>staging</span><span>dev</span>
            </div>
          </div>
          <p class="b-cap">Pick the engines, run once, get merged rows tagged with their source.</p>
        </div>

        <!-- ============== Tile 5 — Version-matched embedded CLI ============== -->
        <div class="bento-tile bento-cli">
          <div class="b-eye mono">Embedded CLI</div>
          <h3 class="b-title"><code class="b-codetag mono">psql</code>, but the right version.</h3>
          <div class="cli-term mono" aria-hidden="true">
            <div class="cli-line"><span class="cli-prompt">$</span> queryden cli pg://db.acme.dev</div>
            <div class="cli-line cli-good">→ detected PostgreSQL <strong>16.4</strong></div>
            <div class="cli-line cli-good">→ using <strong>psql 16.4</strong> <span class="cli-ok">✓ matched</span></div>
            <div class="cli-line cli-fade">psql (16.4)</div>
            <div class="cli-line cli-fade">db=#&nbsp;<span class="cli-cursor"></span></div>
          </div>
          <p class="b-cap">Auto-downloads the matching server-version client. No "version mismatch" surprises.</p>
        </div>

      </div>

      <!-- ============== Keyboard strip ============== -->
      <div class="reveal kbd-strip" role="list" aria-label="Common shortcuts">
        {BENTO_KEYBOARD.map((k) => (
          <div class="kbd-cell" role="listitem">
            <div class="kbd-keys">
              {k.keys.map((key, i) => (
                <>
                  <kbd class="kbd-key">{key}</kbd>
                  {i < k.keys.length - 1 && <span class="kbd-plus">+</span>}
                </>
              ))}
            </div>
            <div class="kbd-label">{k.label}</div>
          </div>
        ))}
      </div>

      <p class="reveal bento-tail mono">
        And about <span class="bt-num">45</span> more — multi-cursor, schema search, transaction
        controls, query history, saved snippets, custom keymap presets, tab cycling, definition
        peek, EXPLAIN cost heatmap, signed updater, SSH tunneling, SQLite per-project files…
        <a href="/docs" class="bt-link">all of them in the docs →</a>
      </p>
    </div>
  </section>

  <!-- ============== SECURITY ============== -->
  <section class="section-pad" id="security" style="border-top: 1px solid var(--line-1);">
    <div class="wrap">
      <div class="reveal section-head">
        <div>
          <div class="eyebrow">Security</div>
          <h2 style="margin-top: 14px;">Credentials, locked to your hardware.</h2>
        </div>
        <p class="lede">
          Every encrypted file is fingerprinted to the machine that wrote it. Copy your connections to another
          laptop and they're noise — by design. <a href="/security" style="color: var(--accent); border-bottom: 1px solid color-mix(in oklch, var(--accent) 40%, transparent);">Read the threat model →</a>
        </p>
      </div>

      <div class="reveal sec-pillars">
        <div class="sec-pillar">
          <div class="eyebrow">Layer</div>
          <h4>AES-256-GCM</h4>
          <p>Authenticated encryption for every connection, every saved query, every vault entry. Tampering invalidates the MAC; the file refuses to decrypt.</p>
        </div>
        <div class="sec-pillar">
          <div class="eyebrow">Layer</div>
          <h4>Argon2id KDF</h4>
          <p>Master password → key via a memory-hard KDF, making brute-force orders of magnitude slower than a GPU farm.</p>
        </div>
        <div class="sec-pillar">
          <div class="eyebrow">Layer</div>
          <h4>Machine fingerprint</h4>
          <p>Mixed into the KDF. Linux: <code class="inline">/etc/machine-id</code>. macOS: <code class="inline">IOPlatformUUID</code>. Windows: <code class="inline">CSP UUID</code>. Change machines, the vault refuses to load.</p>
        </div>
        <div class="sec-pillar">
          <div class="eyebrow">Layer</div>
          <h4>OS keychain</h4>
          <p>Master key in macOS Keychain (Secure Enclave-bound), Windows Credential Manager (DPAPI), or libsecret on Linux.</p>
        </div>
      </div>

      <a class="reveal sec-deepdive" href="/security#vault">
        <div class="sd-left">
          <div class="eyebrow">Deep dive</div>
          <h3 class="sd-title">See the bytes of an encrypted vault.</h3>
          <p class="sd-cap">
            The Security page walks the full file format — magic header, Argon2id salt,
            GCM nonce, ciphertext, MAC — annotated against the source. Plus the threat
            model: what we defend against, and what we don't.
          </p>
          <span class="sd-cta mono">Open the threat model <span class="sd-arrow">→</span></span>
        </div>
        <div class="sd-right" aria-hidden="true">
          <div class="sd-hex mono">
            <span class="sd-h-m">51 44 56 4e 5f 02</span>
            <span class="sd-h-s">e7 3a 9c 1f</span>
            <span class="sd-h-n">c4 8e 1a 7f</span>
            <span class="sd-h-c">6f 92 b1 04 d7 8a 3e cc</span>
            <span class="sd-h-c">f1 27 5b 84 a0 19 6d e3</span>
            <span class="sd-h-t">b8 14 6a 92 f3 0d 4e 27</span>
          </div>
        </div>
      </a>
    </div>
  </section>

  <!-- ============== COMPARE ============== -->
  <section class="section-pad" id="compare" style="border-top: 1px solid var(--line-1);">
    <div class="wrap">
      <div class="reveal section-head">
        <div>
          <div class="eyebrow">How we compare</div>
          <h2 style="margin-top: 14px;">Six tools, side-by-side.</h2>
        </div>
        <p class="lede">
          Verified against each project's public docs and changelog. Hover a column to highlight; we've left the gaps where the gaps are.
        </p>
      </div>

      <div class="reveal compare-toolbar">
        <div class="ct-tools-meta mono">{ROWS.length} rows · 6 tools · cyan column = QueryDen</div>
        <div class="ct-toggle" role="group" aria-label="Filter mode">
          <button type="button" class="ct-tog ct-tog-active" data-mode="all">All ({ROWS.length})</button>
          <button type="button" class="ct-tog" data-mode="wedge">Wins only ({WEDGE_COUNT})</button>
        </div>
      </div>

      <div class="reveal compare-wrap" id="compare-table">
        <div class="ct-head-row">
          <div class="ct-cap-head">Capability</div>
          {COMPETITORS.map((c, i) => (
            <button
              type="button"
              class={`ct-col-head${c.ours ? ' ours' : ''}`}
              data-col={i}
              aria-label={`Highlight ${c.name} column`}
            >
              <div class="cn">{c.name}</div>
              <div class="cs mono">{c.sub}</div>
            </button>
          ))}
        </div>
        {ROWS.map((row) => (
          <div class={`ct-row${row.wedge ? ' ct-row-wedge' : ''}`}>
            <div class="ct-rowhead">{row.label}</div>
            {row.values.map((v, i) => (
              <div class={`ct-cell${COMPETITORS[i].ours ? ' ours' : ''}${v === false ? ' is-no' : ''}`} data-col={i}>
                {v === true && (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="ct-yes"><path d="m5 12 4.5 4.5L19 7"/></svg>
                )}
                {v === false && <span class="ct-no">—</span>}
                {typeof v === 'string' && <span class="ct-txt">{v}</span>}
              </div>
            ))}
          </div>
        ))}
      </div>

      <!-- Mobile fallback: the full 7-column table is unusable on a phone.
           Show a focused wedge-wins summary + direct links to each
           dedicated comparison page. -->
      <div class="reveal compare-mobile" aria-label="QueryDen advantages and per-tool comparisons">
        <div class="compare-mobile-card">
          <div class="compare-mobile-eye">QueryDen wedge wins</div>
          <ul class="compare-mobile-list">
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 4.5 4.5L19 7"/></svg>
              ~11 MB native installer
            </li>
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 4.5 4.5L19 7"/></svg>
              No Chromium bundled
            </li>
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 4.5 4.5L19 7"/></svg>
              Machine-locked vault, brute-force lockout
            </li>
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 4.5 4.5L19 7"/></svg>
              Integrated psql (per Postgres version)
            </li>
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 4.5 4.5L19 7"/></svg>
              AI assistant — BYO key, 4 providers
            </li>
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 4.5 4.5L19 7"/></svg>
              Zero app telemetry by default
            </li>
          </ul>
          <div class="compare-mobile-vs">
            <a href="/compare/dbeaver">vs DBeaver</a>
            <a href="/compare/datagrip">vs DataGrip</a>
            <a href="/compare/tableplus">vs TablePlus</a>
            <a href="/compare/pgadmin">vs pgAdmin</a>
            <a href="/compare/beekeeper">vs Beekeeper</a>
            <a href="/compare">All comparisons →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== CTA ============== -->
  <section class="cta-wrap" id="cta">
    <SignatureMesh intensity="subtle" maskFalloff="hard" />
    <div class="wrap cta-inner">
      <div class="reveal">
        <div class="eyebrow" style="justify-content: center;">Ship the small one</div>
        <h2 class="cta-title display">Stop waiting for a database client to start.</h2>
        <p class="lede-lg cta-lede">
          An 11&nbsp;MB installer. Native binaries on macOS, Windows, and Linux. MIT licensed. Zero app telemetry.
        </p>
        <div class="cta-buttons">
          <a class="btn btn-lg btn-accent" href="/download">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12"/><path d="m7 10 5 5 5-5"/><path d="M5 21h14"/></svg>
            <span data-os-cta>Download QueryDen</span>
          </a>
          <a class="btn btn-lg btn-ghost" href={SITE.repo} rel="noopener">View on GitHub</a>
        </div>
        <p class="mono cta-foot">
          {RELEASE.tag} · published {RELEASE.publishedAt} · SHA-256 verified · <a href="/download">all platforms</a>
        </p>
      </div>
    </div>
  </section>

</Layout>

<style is:global>
  /* ========== Hero ========== */
  .hero {
    position: relative;
    padding-top: clamp(48px, 6.5vh, 96px);
    padding-bottom: clamp(40px, 6vh, 72px);
    overflow: hidden;
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    display: flex; flex-direction: column; align-items: center;
    text-align: center;
  }
  .hero-pill {
    margin-bottom: 28px;
    max-width: calc(100% - 8px);
  }
  .hero-pill-link {
    text-decoration: none;
    transition: border-color var(--t-fast) var(--ease), background var(--t-fast) var(--ease), color var(--t-fast) var(--ease);
  }
  /* On narrow viewports keep the pill on a single, readable line. */
  @media (max-width: 560px) {
    .hero-pill { height: auto; padding: 4px 12px; }
    .hero-pill-sep,
    .hero-pill-detail { display: none; }
  }
  .hero-pill-link:hover {
    border-color: color-mix(in oklch, var(--accent) 55%, var(--line-2));
    background: color-mix(in oklch, var(--accent) 6%, var(--bg-1));
    color: var(--ink-0);
  }
  .hero-pill-link:hover .hero-pill-arrow { transform: translateX(2px); }
  .hero-pill-sep { color: var(--ink-3); }
  .hero-pill-detail { color: var(--ink-2); }
  .hero-pill-link:hover .hero-pill-detail { color: var(--ink-1); }
  .hero-pill-arrow {
    color: var(--accent);
    margin-left: 2px;
    transition: transform var(--t-fast) var(--ease);
    display: inline-block;
  }
  .hero-em { color: var(--ink-0); position: relative; display: inline-block; }
  .hero-em::after {
    content: ''; position: absolute; left: 0; right: 0; bottom: -4px;
    height: 4px;
    background:
      linear-gradient(90deg,
        transparent 0%,
        color-mix(in oklch, var(--accent) 80%, transparent) 8%,
        color-mix(in oklch, var(--accent) 80%, transparent) 92%,
        transparent 100%);
    transform: scaleX(0.6);
    transform-origin: center;
    opacity: 0;
    animation: hero-underline 1.4s var(--ease) 0.8s forwards;
  }
  @keyframes hero-underline {
    to { transform: scaleX(1); opacity: 1; }
  }
  .hero-lede { margin: 28px auto 0; }
  .hero-cta { display: flex; gap: 12px; margin-top: 40px; flex-wrap: wrap; justify-content: center; }
  .hero-foot {
    margin-top: 28px; color: var(--ink-3); font-size: 12px;
  }

  /* ---- Hero demo strip ---- */
  .hero-demo {
    margin: 56px auto 28px;
    width: 100%;
    max-width: 760px;
    perspective: 1200px;
  }
  .hd-frame {
    text-align: left;
    border: 1px solid var(--line-1);
    border-radius: var(--r-3);
    overflow: hidden;
    background: linear-gradient(180deg,
      color-mix(in oklch, var(--bg-1) 100%, transparent) 0%,
      color-mix(in oklch, var(--bg-0) 30%, transparent) 100%);
    box-shadow:
      0 1px 0 color-mix(in oklch, white 4%, transparent) inset,
      0 24px 48px -24px rgba(0,0,0,0.6),
      0 80px 120px -48px color-mix(in oklch, var(--accent) 12%, transparent);
  }
  .hd-chrome {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 12px;
    padding: 10px 14px;
    border-bottom: 1px solid var(--line-1);
    background: linear-gradient(180deg,
      color-mix(in oklch, var(--bg-2) 80%, transparent) 0%,
      color-mix(in oklch, var(--bg-1) 80%, transparent) 100%);
  }
  .hd-lights { display: inline-flex; align-items: center; gap: 6px; }
  .hd-light {
    width: 11px; height: 11px;
    border-radius: 50%;
    display: inline-block;
    box-shadow: inset 0 0 0 1px rgba(0,0,0,0.18);
  }
  .hd-light-r { background: oklch(0.65 0.16 22); }
  .hd-light-y { background: oklch(0.78 0.14 75); }
  .hd-light-g { background: oklch(0.74 0.16 145); }
  .hd-tab {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 11.5px;
    color: var(--ink-1);
    padding: 4px 12px;
    border: 1px solid color-mix(in oklch, var(--line-1) 70%, transparent);
    background: var(--bg-0);
    border-radius: 999px;
    justify-self: center;
  }
  .hd-tab-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 3px color-mix(in oklch, var(--accent) 22%, transparent);
  }
  .hd-tab-meta { color: var(--ink-4); }
  .hd-run {
    font-size: 11px;
    color: var(--ink-3);
    display: inline-flex; align-items: center; gap: 4px;
  }
  .hd-run kbd {
    display: inline-block;
    padding: 0 5px; height: 18px; line-height: 17px;
    border: 1px solid var(--line-2);
    background: var(--bg-2);
    border-radius: 4px;
    font-family: var(--mono);
    font-size: 10.5px;
    color: var(--ink-1);
    margin: 0 1px;
  }

  .hd-body { display: flex; flex-direction: column; }
  .hd-editor {
    background:
      linear-gradient(180deg,
        color-mix(in oklch, var(--bg-2) 80%, transparent) 0%,
        color-mix(in oklch, var(--bg-2) 50%, transparent) 100%);
