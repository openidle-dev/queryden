<script>
  // OS-detect for the hero + CTA download labels.
  const labels = document.querySelectorAll('[data-os-cta]');
  if (labels.length) {
    const ua = navigator.userAgent;
    const platform = (navigator as any).userAgentData?.platform || navigator.platform || '';
    const isMac = /Mac/i.test(platform) || /Mac OS X/i.test(ua);
    const isWin = /Win/i.test(platform) || /Windows/i.test(ua);
    const isLinux = /Linux/i.test(platform) && !/Android/i.test(ua);
    let label = 'Download QueryDen';
    if (isMac) label = 'Download for macOS';
    else if (isWin) label = 'Download for Windows';
    else if (isLinux) label = 'Download for Linux';
    labels.forEach((el) => (el.textContent = label));
  }

  // Hero demo strip — type the SQL line by line, reveal the result panel.
  const heroDemo = document.getElementById('hero-demo');
  if (heroDemo) {
    const rows = [
      '<span class="hd-kw">SELECT</span> u.email <span class="hd-kw">AS</span> customer, <span class="hd-fn">count</span>(o.id) <span class="hd-kw">AS</span> orders,',
      '       <span class="hd-fn">sum</span>(o.total)::<span class="hd-id">money</span> <span class="hd-kw">AS</span> total',
      '<span class="hd-kw">FROM</span> users u <span class="hd-kw">JOIN</span> orders o <span class="hd-kw">ON</span> u.id <span class="hd-op">=</span> o.user_id',
      '<span class="hd-kw">GROUP BY</span> u.email <span class="hd-kw">ORDER BY</span> total <span class="hd-kw">DESC</span> <span class="hd-kw">LIMIT</span> 3;',
    ];
    const targets = [1,2,3,4].map(i => document.getElementById(`hd-row-${i}`)!);

    // Strip tags to compute per-character timing; we type the rendered HTML.
    const stripped = rows.map(r => r.replace(/<[^>]+>/g, ''));

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (reducedMotion) {
      rows.forEach((html, i) => { targets[i].innerHTML = html; });
      heroDemo.classList.add('has-result');
    } else {
      let rowIdx = 0;
      let charIdx = 0;
      let typingTimer: number | null = null;
      const PER_CHAR = 16;

      const typeNext = () => {
        if (rowIdx >= rows.length) {
          targets[targets.length - 1].classList.remove('is-active');
          window.setTimeout(() => {
            heroDemo.classList.add('has-result');
            const status = document.getElementById('hd-status');
            if (status) status.textContent = '3 rows · 14 ms · cached plan';
          }, 320);
          return;
        }
        const row = rows[rowIdx];
        const plain = stripped[rowIdx];

        targets.forEach((t, i) => t.classList.toggle('is-active', i === rowIdx));

        // Walk source HTML by visible character count, copying tag markers as we go.
        let outHtml = '';
        let seen = 0;
        let i = 0;
        while (i < row.length && seen <= charIdx) {
          const ch = row[i];
          if (ch === '<') {
            const end = row.indexOf('>', i);
            if (end === -1) break;
            outHtml += row.slice(i, end + 1);
            i = end + 1;
          } else {
            outHtml += ch;
            seen++;
            i++;
          }
        }
        targets[rowIdx].innerHTML = outHtml;

        charIdx++;
        if (charIdx > plain.length) {
          rowIdx++;
          charIdx = 0;
        }
        typingTimer = window.setTimeout(typeNext, PER_CHAR);
      };

      const startTyping = () => {
        if (typingTimer !== null) return;
        typingTimer = window.setTimeout(typeNext, 320);
      };

      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver((entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              startTyping();
              io.unobserve(heroDemo);
            }
          }
        }, { threshold: 0.3 });
        io.observe(heroDemo);
      } else {
        startTyping();
      }
    }
  }

  // Bento Cmd+K palette — keystrokes drive the right-hand pane.
  const bcmd = document.getElementById('bcmd');
  if (bcmd) {
    const input = bcmd.querySelector<HTMLInputElement>('.bcmd-input')!;
    const items = Array.from(bcmd.querySelectorAll<HTMLButtonElement>('.bcmd-item'));
    const panes = Array.from(bcmd.querySelectorAll<HTMLElement>('.bcmd-pane'));

    const KEYWORDS: Record<string, string[]> = {
      explain: ['explain', 'analyze', 'plan', 'cost', 'tree', 'slow'],
      ai:      ['ai', 'ask', 'optim', 'index', 'suggest', 'chatgpt', 'claude', 'gemini', 'ollama'],
      join:    ['join', 'on', 'foreign', 'fk', 'autocomplete'],
      compare: ['compare', 'diff', 'schema', 'migration'],
      history: ['history', 'undo', 'revert', 'snapshot'],
      mask:    ['mask', 'hide', 'screenshot', 'screenshare', 'redact'],
    };

    const AI_TEXT = '-- Suggested by AI based on EXPLAIN output:\nCREATE INDEX CONCURRENTLY\n  idx_orders_customer_email\n  ON orders (customer_email)\n  WHERE total > 1000;';

    type Cmd = 'explain' | 'ai' | 'join' | 'compare' | 'history' | 'mask';

    const match = (q: string): Cmd => {
      const Q = q.trim().toLowerCase();
      if (!Q) return 'explain';
      for (const cmd of items.map(it => it.dataset.cmd as Cmd)) {
        const kws = KEYWORDS[cmd] ?? [];
        if (kws.some(k => k.startsWith(Q) || Q.startsWith(k) || k.includes(Q))) return cmd;
      }
      return items[0].dataset.cmd as Cmd;
    };

    let aiTimer: number | null = null;
    const playAiTyping = () => {
      const target = bcmd.querySelector<HTMLElement>('.ai-cur');
      if (!target) return;
      if (aiTimer) window.clearInterval(aiTimer);
      target.textContent = '';
      let i = 0;
      aiTimer = window.setInterval(() => {
        if (i >= AI_TEXT.length) {
          if (aiTimer) window.clearInterval(aiTimer);
          aiTimer = null;
          return;
        }
        target.textContent = AI_TEXT.slice(0, ++i);
      }, 18);
    };

    const setActive = (cmd: Cmd) => {
      items.forEach(it => {
        const me = it.dataset.cmd === cmd;
        it.classList.toggle('is-active', me);
      });
      panes.forEach(p => p.classList.toggle('is-active', p.dataset.pane === cmd));
      if (cmd === 'ai') playAiTyping();
    };

    const onInput = () => {
      setActive(match(input.value));
    };

    input.addEventListener('input', onInput);
    items.forEach(it => {
      it.addEventListener('click', () => {
        input.value = it.dataset.cmd ?? '';
        setActive(it.dataset.cmd as Cmd);
      });
    });

    // Demo on first reveal: type a sequence so the visitor sees what's possible.
    const DEMO: Array<[Cmd, string]> = [
      ['explain', 'explain'],
      ['ai',      'ai'],
      ['join',    'join'],
      ['compare', 'compare'],
      ['history', 'history'],
      ['mask',    'mask'],
      ['explain', 'explain'],
    ];
    let demoIdx = 0;
    let demoTimer: number | null = null;
    let userTouched = false;
    const stepDemo = () => {
      if (userTouched) return;
      const [cmd, text] = DEMO[demoIdx % DEMO.length];
      input.value = text;
      onInput();
      demoIdx++;
      demoTimer = window.setTimeout(stepDemo, cmd === 'ai' ? 4500 : 2600);
    };
    const stopDemo = () => {
      userTouched = true;
      if (demoTimer) window.clearTimeout(demoTimer);
    };
    input.addEventListener('focus', stopDemo);
    input.addEventListener('keydown', stopDemo);
    bcmd.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('.bcmd-item')) stopDemo();
    });

    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (e.isIntersecting && !userTouched && demoTimer === null) {
            stepDemo();
            io.unobserve(bcmd);
          }
        }
      }, { threshold: 0.4 });
      io.observe(bcmd);
    } else {
      stepDemo();
    }
  }

  // Footprint chart — trigger the constant-rate fill once the chart is in view.
  const fp = document.querySelector<HTMLElement>('.footprint-chart');
  if (fp && 'IntersectionObserver' in window) {
    const fpIo = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          fp.classList.add('go');
          fpIo.unobserve(fp);
        }
      }
    }, { threshold: 0.35 });
    fpIo.observe(fp);
  } else if (fp) {
    fp.classList.add('go');
  }

  // Compare table — column hover highlight.
  const ct = document.getElementById('compare-table');
  if (ct) {
    const heads = ct.querySelectorAll<HTMLButtonElement>('.ct-col-head');
    const cells = ct.querySelectorAll<HTMLDivElement>('.ct-cell');
    const setCol = (col: number) => {
      heads.forEach((h, i) => h.classList.toggle('active', i === col));
      cells.forEach((c) => c.classList.toggle('col-active', Number(c.dataset.col) === col));
    };
    heads.forEach((h, i) => {
      h.addEventListener('mouseenter', () => setCol(i));
      h.addEventListener('focus', () => setCol(i));
    });
    setCol(0);

    const togs = document.querySelectorAll<HTMLButtonElement>('.ct-tog');
    togs.forEach((t) => {
      t.addEventListener('click', () => {
        const mode = t.dataset.mode;
        togs.forEach((other) => other.classList.toggle('ct-tog-active', other === t));
        ct.classList.toggle('wedge-mode', mode === 'wedge');
      });
    });
  }
</script>
