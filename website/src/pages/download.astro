---
import Layout from '../layouts/Layout.astro';
import { SITE, RELEASE, downloadUrl, shaUrl } from '../lib/site';

const groups = (['macOS', 'Windows', 'Linux'] as const).map((os) => ({
  os,
  assets: RELEASE.assets.filter((a) => a.os === os),
}));

const winFile = RELEASE.assets.find((a) => a.os === 'Windows' && a.primary)?.file ?? '';
const macFile = RELEASE.assets.find((a) => a.os === 'macOS' && a.primary)?.file ?? '';
const debFile = RELEASE.assets.find((a) => a.os === 'Linux' && a.primary && /\.deb$/.test(a.file))?.file ?? '';
const verifyCmds = [
  { label: 'PowerShell',          cmd: `Get-FileHash ${winFile} -Algorithm SHA256` },
  { label: 'macOS / Linux',       cmd: `shasum -a 256 ${macFile}` },
  { label: 'Linux (coreutils)',   cmd: `sha256sum ${debFile}` },
];

const requirements = [
  { title: 'macOS',   items: ['macOS 11 Big Sur or newer', 'Apple Silicon only (no Intel build right now)', 'Universal WKWebView (system)'] },
  { title: 'Windows', items: ['Windows 10 1809 or newer', 'x86_64', 'WebView2 runtime (auto-installed)'] },
  { title: 'Linux',   items: ['glibc 2.31+ (Debian 11 / Ubuntu 22.04+)', 'webkit2gtk 4.1', 'libsecret / GNOME Keyring for the vault'] },
];
---
<Layout title="Download · QueryDen" active="download">

  <header class="page-hero">
    <div class="grid-bg"></div>
    <div class="wrap">
      <div class="eyebrow">Release · {RELEASE.tag}</div>
      <h1 style="margin-top: 22px;">Native installers.<br/>No browser bundled.</h1>
      <p class="lede">
        Built in Rust on Tauri 2. Pick your platform — installers are 8–11 MB on macOS,
        Windows, and Linux (.deb). The AppImage bundles its own runtime, so it's larger.
      </p>
      <div class="release-meta">
        <span>Published <strong>{RELEASE.publishedAt}</strong></span>
        <span>·</span>
        <span>SHA-256 verified</span>
        <span>·</span>
        <span>Built reproducibly on GitHub Actions</span>
        <span>·</span>
        <span>Zero telemetry</span>
      </div>
    </div>
  </header>

  <section class="sec-pad" id="downloads">
    <div class="wrap">
      <div class="os-grid">
        {groups.map((g, i) => (
          <div class={`card os-card${i === 0 ? ' featured' : ''}`}>
            <div class="os-icon">
              {g.os === 'macOS' && (
                <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
                  <path d="M16.4 1.5c.1 1.1-.3 2.2-1 3-.7.8-1.8 1.4-2.9 1.3-.1-1.1.4-2.2 1-2.9.7-.8 1.9-1.3 2.9-1.4zm3.3 17.8c-.6 1.4-1 2-1.7 3.2-1 1.7-2.4 3.8-4.2 3.8-1.6 0-2-1-4.1-1-2.1 0-2.6 1-4.1 1-1.8 0-3.2-1.9-4.1-3.6-2.7-4.7-3-10.3-1.3-13.3 1.2-2.1 3.1-3.4 4.9-3.4 1.8 0 2.9 1 4.4 1 1.4 0 2.3-1 4.4-1 1.6 0 3.3.9 4.5 2.4-4 2.2-3.3 7.9.3 8.9z"/>
                </svg>
              )}
              {g.os === 'Windows' && (
                <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
                  <path d="M3 5.6 10.3 4.5v6.9H3zM11.4 4.4 21 3v8.4h-9.6zM3 12.5h7.3v6.9L3 18.4zM11.4 12.6H21V21l-9.6-1.4z"/>
                </svg>
              )}
              {g.os === 'Linux' && (
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <circle cx="12" cy="9" r="4"/>
                  <path d="M8 13c-1 2-3 5-3 8h14c0-3-2-6-3-8"/>
                </svg>
              )}
            </div>
            <h3>{g.os}</h3>
            <div class="vrec">{g.assets[0].arch.replace(/·.+/, '').trim() || 'native'}</div>
            <div class="packages">
              {g.assets.map((a, idx) => (
                <a class={`pkg${idx === 0 ? ' recommended' : ''}`} href={downloadUrl(a.file)} rel="noopener">
                  <span class="name">{a.file}</span>
                  {idx === 0 && <span class="tag-rec">recommended</span>}
                  <span class="arch">{a.arch}</span>
                  <span class="size">{a.sizeMB}&nbsp;MB</span>
                </a>
              ))}
              <a class="pkg pkg-sha" href={shaUrl(g.assets[0].file)} rel="noopener">
                <span class="name">{g.assets[0].file}.sha256</span>
                <span class="arch">checksum</span>
              </a>
            </div>
          </div>
        ))}
      </div>

      <p class="all-assets">
        Full asset list (including SHA-256 files) →
        <a href={`${SITE.repo}/releases/tag/${RELEASE.tag}`} rel="noopener">{SITE.repo.replace('https://', '')}/releases/tag/{RELEASE.tag}</a>
      </p>
    </div>
  </section>

  <section class="sec-pad-sm" id="verify" style="border-top: 1px solid var(--line);">
    <div class="wrap two-col">
      <div>
        <div class="eyebrow">Verify your download</div>
        <h2 class="s-title">Every binary ships with its SHA-256.</h2>
        <p style="margin-top: 16px; max-width: 480px;">
          Each installer has a matching <code class="inline">.sha256</code> next to it on the GitHub release page.
          Download both and compare — if the hashes don't match, don't run the installer.
        </p>
      </div>
      <div class="verify-cmds">
        {verifyCmds.map((v) => (
          <div class="vcmd">
            <div class="vcmd-label">{v.label}</div>
            <pre class="code">{v.cmd}</pre>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="sec-pad-sm" id="requirements" style="border-top: 1px solid var(--line);">
    <div class="wrap">
      <div class="eyebrow">System requirements</div>
      <h2 class="s-title">What you need to run it.</h2>
      <div class="req-grid s-content">
        {requirements.map((r) => (
          <div class="card req">
            <h4>{r.title}</h4>
            <ul>
              {r.items.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="sec-pad-sm" id="build" style="border-top: 1px solid var(--line);">
    <div class="wrap two-col">
      <div>
        <div class="eyebrow">Build from source</div>
        <h2 class="s-title">Or compile it yourself.</h2>
        <p style="margin-top: 16px; max-width: 520px;">
          Don't trust the binaries? Don't have to. The repo builds on macOS, Windows, and Linux with
          Rust + Node. Full instructions in the README.
        </p>
        <p style="margin-top: 18px;">
          <a class="btn btn-ghost" href={SITE.repo} rel="noopener">View on GitHub</a>
        </p>
      </div>
      <pre class="code">git clone {SITE.repo}.git
cd queryden
npm install
npm run tauri build</pre>
    </div>
  </section>

</Layout>

<style>
  .release-meta {
    display: flex; flex-wrap: wrap; gap: 14px; align-items: center;
    margin-top: 28px; font-family: var(--mono); font-size: 12px; color: var(--ink-3);
  }
  .release-meta strong { color: var(--ink-2); font-weight: 500; }

  .os-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  @media (max-width: 1000px) { .os-grid { grid-template-columns: 1fr; } }
  .os-card { padding: 28px; display: flex; flex-direction: column; }
  .os-card.featured { border-color: color-mix(in oklch, var(--accent) 40%, var(--line)); }
  .os-icon {
    width: 36px; height: 36px; border-radius: 8px;
    background: var(--bg-2); border: 1px solid var(--line);
    display: grid; place-items: center; margin-bottom: 14px;
  }
  .os-card h3 { font-size: 22px; margin: 0; }
  .vrec { font-family: var(--mono); font-size: 11.5px; color: var(--ink-3); margin-top: 4px; margin-bottom: 18px; }
  .packages { display: flex; flex-direction: column; gap: 8px; }
  .pkg {
    display: grid; grid-template-columns: 1fr auto auto; gap: 10px; align-items: center;
    padding: 10px 14px; border-radius: 8px;
    border: 1px solid var(--line); background: var(--bg);
    font-family: var(--mono); font-size: 12px; color: var(--ink-2);
    transition: border-color .15s, background .15s;
  }
  .pkg:hover { border-color: var(--line-2); background: var(--bg-1); }
  .pkg.recommended { border-color: var(--accent); }
  .pkg .name { color: var(--ink); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .pkg .arch, .pkg .size { color: var(--ink-3); font-size: 11px; }
  .pkg .tag-rec {
    color: var(--accent); font-size: 10.5px; letter-spacing: 0.06em; text-transform: uppercase;
  }
  .pkg-sha .name { color: var(--ink-3); }

  .all-assets {
    margin-top: 28px; text-align: center;
    font-family: var(--mono); font-size: 12.5px; color: var(--ink-3);
  }
  .all-assets a { color: var(--ink-2); border-bottom: 1px solid var(--line-2); }
  .all-assets a:hover { color: var(--ink); }

  .two-col {
    display: grid; grid-template-columns: 1fr 1fr; gap: 56px; align-items: center;
  }
  @media (max-width: 900px) { .two-col { grid-template-columns: 1fr; } }

  .verify-cmds { display: flex; flex-direction: column; gap: 14px; }
  .vcmd-label {
    font-family: var(--mono); font-size: 11px; color: var(--ink-3);
    letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 6px;
  }

  .req-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  @media (max-width: 900px) { .req-grid { grid-template-columns: 1fr; } }
  .req { padding: 22px 24px; }
  .req h4 { font-family: var(--mono); font-size: 11.5px; letter-spacing: 0.12em;
            text-transform: uppercase; color: var(--ink-3); margin-bottom: 14px; }
  .req ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px; }
  .req li { font-size: 14px; color: var(--ink-2); line-height: 1.45;
            padding-left: 18px; position: relative; }
  .req li::before {
    content: ''; position: absolute; left: 0; top: 9px;
    width: 6px; height: 6px; border-radius: 50%;
    background: color-mix(in oklch, var(--accent) 60%, var(--line));
  }
</style>
