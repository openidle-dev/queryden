---
import Layout from '../layouts/Layout.astro';
import { SITE } from '../lib/site';

const quickstart = [
  {
    n: '01',
    title: 'Install',
    body: 'Grab the installer for your OS from the download page. Native installers are 8–11 MB. The .deb and .dmg are signed; the AppImage is portable.',
    link: { href: '/download', label: 'Download QueryDen' },
  },
  {
    n: '02',
    title: 'Set a master password',
    body: 'On first launch you create the master password for your encrypted vault. This password never leaves your machine — it is mixed with a machine fingerprint to derive the encryption key.',
    link: { href: '/security#vault', label: 'How the vault works' },
  },
  {
    n: '03',
    title: 'Add a connection',
    body: 'New Connection → pick Postgres, MySQL, SQLite, CockroachDB, or Supabase. Optional SSH tunnel for jump-host setups. Connections are stored encrypted, locked to this machine.',
    link: null,
  },
  {
    n: '04',
    title: 'Run a query',
    body: 'Ctrl+Enter executes the SQL under your cursor. Ctrl+Shift+L formats it. Results land in a Glide grid; EXPLAIN ANALYZE renders as a visual plan tree.',
    link: null,
  },
];

const engines = [
  { name: 'PostgreSQL',  detail: 'Native driver via the patched tauri-plugin-sql. INTERVAL, OID, and array types supported.' },
  { name: 'MySQL',       detail: 'Native driver. All standard types + JSON.' },
  { name: 'MariaDB',     detail: 'MySQL-compatible driver path.' },
  { name: 'SQLite',      detail: 'File-path connections; multiple DB files per project.' },
  { name: 'CockroachDB', detail: 'Postgres wire protocol — uses the PG driver.' },
  { name: 'Supabase',    detail: 'Postgres driver + Supabase-specific connection URL helpers.' },
];

const links = [
  { eyebrow: 'README', title: 'Project overview', meta: 'Architecture, commands, contributing.', href: `${SITE.repo}/blob/main/README.md` },
  { eyebrow: 'Issues', title: 'Report a bug or request a feature', meta: 'GitHub Issues — public, searchable.',     href: `${SITE.repo}/issues` },
  { eyebrow: 'Source', title: 'Read the storage encryption code', meta: '~300 lines of Rust in src-tauri/.',         href: `${SITE.repo}/blob/main/src-tauri/src/storage.rs` },
  { eyebrow: 'Build',  title: 'Build from source',                meta: 'macOS, Windows, Linux — instructions in README.', href: `${SITE.repo}#building` },
];

const keymaps = [
  { keys: 'Ctrl+Enter',   action: 'Run query under cursor / selection' },
  { keys: 'Ctrl+Shift+L', action: 'Format SQL' },
  { keys: 'Ctrl+H',       action: 'Open help' },
  { keys: 'Ctrl+Alt+S',   action: 'Open settings' },
  { keys: 'Ctrl+T',       action: 'New query tab' },
  { keys: 'Ctrl+W',       action: 'Close current tab (when more than one is open)' },
];
---
<Layout title="Docs · QueryDen" active="docs">

  <header class="page-hero">
    <div class="grid-bg"></div>
    <div class="wrap">
      <div class="eyebrow">Documentation</div>
      <h1 style="margin-top: 22px;">Get connected in under a minute.</h1>
      <p class="lede">
        QueryDen is intentionally small — there's not a lot of UI to learn. This page covers the
        four-step setup, the engine list, the default keymap, and where to dig deeper.
      </p>
    </div>
  </header>

  <section class="sec-pad" id="quickstart">
    <div class="wrap">
      <div class="eyebrow">Quickstart</div>
      <h2 class="s-title">Four steps from install to first query.</h2>
      <div class="qs-grid s-content">
        {quickstart.map((q) => (
          <div class="card qs">
            <div class="qs-n mono">{q.n}</div>
            <h3>{q.title}</h3>
            <p>{q.body}</p>
            {q.link && (
              <a class="qs-link" href={q.link.href}>{q.link.label} →</a>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="sec-pad-sm" id="connections" style="border-top: 1px solid var(--line);">
    <div class="wrap">
      <div class="eyebrow">Supported engines</div>
      <h2 class="s-title">Six databases, one binary.</h2>
      <div class="eng-grid s-content">
        {engines.map((e) => (
          <div class="eng">
            <div class="eng-name">{e.name}</div>
            <div class="eng-detail">{e.detail}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="sec-pad-sm" id="keymaps" style="border-top: 1px solid var(--line);">
    <div class="wrap">
      <div class="eyebrow">Default keymap</div>
      <h2 class="s-title">What's bound, out of the box.</h2>
      <p class="s-lede" style="max-width: 560px;">
        Per-feature keymaps live in <code class="inline">keymapStore</code> and can be edited in Settings.
        These are the global shortcuts wired in <code class="inline">App.tsx</code>.
      </p>
      <div class="km-list s-content">
        {keymaps.map((k) => (
          <div class="km-row">
            <kbd class="km-keys">{k.keys}</kbd>
            <div class="km-action">{k.action}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="sec-pad-sm" id="more" style="border-top: 1px solid var(--line);">
    <div class="wrap">
      <div class="eyebrow">Dig deeper</div>
      <h2 class="s-title">Everything else is in the repo.</h2>
      <div class="link-grid s-content">
        {links.map((l) => (
          <a class="card link-card" href={l.href} rel="noopener">
            <div class="lc-eye">{l.eyebrow}</div>
            <div class="lc-title">{l.title}</div>
            <div class="lc-meta">{l.meta}</div>
          </a>
        ))}
      </div>
    </div>
  </section>

</Layout>

<style>
  .qs-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 18px; }
  @media (max-width: 800px) { .qs-grid { grid-template-columns: 1fr; } }
  .qs { padding: 28px; }
  .qs-n { font-size: 11px; letter-spacing: 0.14em; color: var(--ink-4); }
  .qs h3 { margin: 12px 0 10px; font-size: 18px; }
  .qs p { font-size: 14.5px; color: var(--ink-2); line-height: 1.6; }
  .qs-link { display: inline-block; margin-top: 14px; color: var(--accent); font-size: 13.5px; font-family: var(--mono); }
  .qs-link:hover { color: var(--accent-w); }

  .eng-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0; border-top: 1px solid var(--line); }
  @media (max-width: 900px) { .eng-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .eng-grid { grid-template-columns: 1fr; } }
  .eng { padding: 20px 0; border-bottom: 1px solid var(--line); padding-right: 22px; }
  .eng-name { font-size: 15px; color: var(--ink); font-weight: 500; }
  .eng-detail { color: var(--ink-3); font-size: 13.5px; margin-top: 6px; line-height: 1.55; }

  .km-list { display: flex; flex-direction: column; gap: 0; border-top: 1px solid var(--line); }
  .km-row {
    display: grid; grid-template-columns: 180px 1fr; gap: 24px; align-items: center;
    padding: 14px 0; border-bottom: 1px solid var(--line);
  }
  .km-keys {
    font-family: var(--mono); font-size: 12px; color: var(--ink);
    background: var(--bg-2); border: 1px solid var(--line-2);
    padding: 4px 10px; border-radius: 6px; align-self: start; width: max-content;
  }
  .km-action { color: var(--ink-2); font-size: 14.5px; }

  .link-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
  @media (max-width: 800px) { .link-grid { grid-template-columns: 1fr; } }
  .link-card { padding: 22px 26px; display: block; color: inherit; transition: border-color .15s, background .15s; }
  .link-card:hover { border-color: var(--line-2); background: var(--bg-2); }
  .lc-eye { font-family: var(--mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-3); }
  .lc-title { font-size: 16px; color: var(--ink); font-weight: 500; margin-top: 8px; }
  .lc-meta { font-size: 13px; color: var(--ink-3); margin-top: 6px; line-height: 1.55; }
</style>
