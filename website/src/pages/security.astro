---
import Layout from '../layouts/Layout.astro';
import SignatureMesh from '../components/SignatureMesh.astro';
import { SITE } from '../lib/site';

const principles = [
  {
    title: 'Credentials never leave your machine',
    body: 'No cloud sync. No "log in to QueryDen". The vault file is encrypted on disk, the encryption key never leaves your computer, and the file is useless if copied to another laptop.',
  },
  {
    title: 'The app has no telemetry and no usage analytics',
    body: 'The desktop app does not report what you do with it. Not on launch, not when you connect, not when you crash. The only outbound calls it makes are to your chosen database server and a one-shot update check against the public GitHub releases manifest. This marketing site uses a self-hosted, cookieless analytics endpoint for aggregate page views — it never sees the app.',
  },
  {
    title: 'You can audit every line',
    body: 'The source is on GitHub under MIT. The encryption code is ~300 lines of Rust in `src-tauri/src/storage.rs`. The CI pipeline that builds the binaries is in the same repo. There is no closed-source layer.',
  },
];

const threats = [
  { actor: 'Someone copies your QueryDen vault file off your laptop',
    defense: 'The vault is encrypted with a key derived from your master password + a machine fingerprint. Without the original machine, the file does not decrypt — even with the correct password.' },
  { actor: 'Malware on your laptop tries to brute-force the vault',
    defense: 'After 5 failed unlock attempts the vault locks for an exponentially increasing duration. Argon2id key derivation makes each attempt slow on purpose.' },
  { actor: 'You lose the laptop',
    defense: 'The vault file is encrypted at rest. The master key in your OS keychain is hardware-bound (Secure Enclave on macOS, DPAPI on Windows, libsecret on Linux). A wiped login means the vault becomes permanently unreadable.' },
  { actor: 'A QueryDen update ships a backdoor',
    defense: 'Every release is built by GitHub Actions from a public tag. The SHA-256 of each installer is published. Reproduce the build yourself from the same commit and compare — the hash must match.' },
  { actor: 'You connect to a malicious database server',
    defense: 'QueryDen is the client. The server can return malicious result rows, but the result grid renders them as text. We do not eval, we do not exec, we do not auto-run a follow-up query based on a result.' },
];

// Illustrative bytes from a QueryDen vault file. Layout reflects the real
// AES-256-GCM file format: magic+version, salt, nonce, ciphertext body, MAC.
// Bytes themselves are random — this is a visual, not a live decryption.
type Region = 'magic' | 'salt' | 'nonce' | 'cipher' | 'tag';
const VAULT_BYTES: { hex: string; region: Region }[] = (() => {
  const make = (s: string, region: Region) => s.split(' ').map(hex => ({ hex, region }));
  return [
    ...make('51 44 56 4e 5f 02', 'magic'),
    ...make('e7 3a 9c 1f b8 4d 02 91 75 c0 ae 6b 32 d8 49 a7', 'salt'),
    ...make('c4 8e 1a 7f 5d b2 09 33 e6 4c 91 a8', 'nonce'),
    ...make('6f 92 b1 04 d7 8a 3e cc f1 27 5b 84 a0 19 6d e3 48 0c b7 95 22 fe d4 7a 91 c8 0b 64 e7 a2', 'cipher'),
    ...make('5f b8 14 6a 92 f3 0d 4e 27 c5 91 a8 6f 14 d3 02', 'tag'),
  ];
})();

const layers = [
  { name: 'AES-256-GCM',                detail: 'Authenticated encryption for every connection, every saved query, every vault entry. Tampering invalidates the MAC; the file refuses to decrypt.' },
  { name: 'Argon2id (memory-hard KDF)', detail: 'Master password → encryption key. Memory-hard by design, making brute-force orders of magnitude slower than a GPU farm.' },
  { name: 'Machine fingerprint',        detail: 'Linux: /etc/machine-id. macOS: IOPlatformUUID. Windows: Win32_ComputerSystemProduct.UUID. Mixed into the KDF — change machines, the vault refuses to load.' },
  { name: 'OS keychain master key',     detail: 'macOS Keychain (Secure Enclave-bound) · Windows Credential Manager (DPAPI) · libsecret on Linux. Falls back to a file-based key only if the OS keyring is unavailable.' },
  { name: 'Brute-force lockout',        detail: '5 failed unlocks → exponential backoff. Implemented in atomic counters in-process; the lock persists across app restarts via the encrypted state file.' },
  { name: 'CSP locked to self',         detail: "Tauri's default-src policy disables remote script loading. The renderer cannot fetch arbitrary code from the internet, even if you find an XSS vector." },
];
---
<Layout title="Security · QueryDen" active="security">

  <header class="page-hero">
    <SignatureMesh intensity="normal" maskFalloff="hard" />
    <div class="wrap" style="position: relative; z-index: 1;">
      <div class="eyebrow">Security &amp; encryption</div>
      <h1 style="margin-top: 22px; max-width: 900px;">
        A database manager you can trust with production credentials.
      </h1>
      <p class="lede">
        Three rules: credentials never leave your machine, nothing phones home, and every claim
        on this page can be verified from the source. What follows is how that's actually built.
      </p>
    </div>
  </header>

  <section class="sec-pad" id="principles">
    <div class="wrap">
      <div class="eyebrow">01 · Principles</div>
      <h2 class="s-title" style="max-width: 760px;">What we won't do.</h2>
      <div class="principles s-content">
        {principles.map((p, i) => (
          <div class="card principle">
            <div class="p-num mono">0{i + 1}</div>
            <h3>{p.title}</h3>
            <p>{p.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="sec-pad-sm" id="vault" style="border-top: 1px solid var(--line);">
    <div class="wrap">
      <div class="eyebrow">02 · The vault</div>
      <h2 class="s-title" style="max-width: 760px;">Six layers, all visible in the source.</h2>
      <p class="s-lede" style="max-width: 660px;">
        The encrypted file at <code class="inline">~/.local/share/com.queryden.app/vault.json</code> is
        protected by the layers below. Remove any one and it stops working — that's the test.
      </p>

      <div class="vault-bytes-card s-content">
        <div class="vb-side vb-side-in">
          <div class="vb-eye mono">▲ &nbsp;Input · plaintext credentials</div>
          <pre class="vb-plain mono"><span class="vbp-k">host</span><span class="vbp-eq">=</span><span class="vbp-v">db.acme.dev</span>
<span class="vbp-k">port</span><span class="vbp-eq">=</span><span class="vbp-v">5432</span>
<span class="vbp-k">user</span><span class="vbp-eq">=</span><span class="vbp-v">alice</span>
<span class="vbp-k">password</span><span class="vbp-eq">=</span><span class="vbp-v">correct-horse-battery-staple</span>
<span class="vbp-k">database</span><span class="vbp-eq">=</span><span class="vbp-v">analytics</span>
<span class="vbp-k">ssh</span><span class="vbp-eq">=</span><span class="vbp-v">bastion.acme.dev:22</span></pre>
          <div class="vb-foot mono">5 fields · UTF-8 · human-readable</div>
        </div>

        <div class="vb-sep" aria-hidden="true">
          <div class="vb-sep-line"></div>
          <div class="vb-sep-chip mono">
            Argon2id &nbsp;→&nbsp; AES-256-GCM &nbsp;·&nbsp; key bound to <strong>this machine</strong>
          </div>
          <div class="vb-sep-line"></div>
        </div>

        <div class="vb-side vb-side-out">
          <div class="vb-eye mono">▲ &nbsp;Disk · vault.json bytes</div>
          <div class="vault-dump" aria-hidden="true">
            {Array.from({ length: Math.ceil(VAULT_BYTES.length / 8) }).map((_, rowIdx) => (
              <div class="vd-row" style={`--i:${rowIdx}`}>
                <span class="vd-ofs mono">{(rowIdx * 8).toString(16).padStart(4, '0')}</span>
                {VAULT_BYTES.slice(rowIdx * 8, rowIdx * 8 + 8).map(b => (
                  <span class={`vd-b vd-${b.region} mono`}>{b.hex}</span>
                ))}
              </div>
            ))}
          </div>
          <div class="vault-legend mono">
            <span class="vl-item"><span class="vl-sw vd-magic-bg"></span>magic</span>
            <span class="vl-item"><span class="vl-sw vd-salt-bg"></span>salt · 16 B</span>
            <span class="vl-item"><span class="vl-sw vd-nonce-bg"></span>nonce · 12 B</span>
            <span class="vl-item"><span class="vl-sw vd-cipher-bg"></span>ciphertext</span>
            <span class="vl-item"><span class="vl-sw vd-tag-bg"></span>tag · 16 B</span>
          </div>
        </div>
      </div>

      <p class="vault-bytes-caption mono">
        Illustrative bytes from a vault file. Field layout reflects the real format in
        <a href={`${SITE.repo}/blob/main/src-tauri/src/storage.rs`} class="src-link">storage.rs</a>:
        magic header, Argon2id salt, GCM nonce, encrypted payload, authentication tag.
        Every byte after the header looks like noise — because it is.
      </p>

      <div class="vault-layers-eyebrow mono">The six layers, one by one</div>
      <div class="layers">
        {layers.map((l, i) => (
          <div class="layer">
            <div class="l-i mono">{(i + 1).toString().padStart(2, '0')}</div>
            <div class="l-name">{l.name}</div>
            <div class="l-detail">{l.detail}</div>
          </div>
        ))}
      </div>
      <p style="margin-top: 36px; font-size: 13.5px; color: var(--ink-3);">
        Source: <a href={`${SITE.repo}/blob/main/src-tauri/src/storage.rs`} class="src-link">src-tauri/src/storage.rs</a>
      </p>
    </div>
  </section>

  <section class="sec-pad-sm" id="threats" style="border-top: 1px solid var(--line);">
    <div class="wrap">
      <div class="eyebrow">03 · Threat model</div>
      <h2 class="s-title" style="max-width: 760px;">What we defend against — and what we don't.</h2>
      <div class="threats s-content">
        {threats.map((t) => (
          <div class="threat">
            <div class="t-actor"><span class="t-bullet">▲</span>{t.actor}</div>
            <div class="t-defense">{t.defense}</div>
          </div>
        ))}
      </div>
      <div class="card limits s-content">
        <div class="eyebrow" style="margin-bottom: 12px;">What we do <em>not</em> defend against</div>
        <ul>
          <li>A rooted/compromised OS. If an attacker controls your kernel they control your memory; no userland app can recover from this.</li>
          <li>A keylogger that captures your master password at the keyboard.</li>
          <li>A network attacker between you and a database that lacks TLS. Use SSL/TLS or our SSH tunnel — that's what they're for.</li>
          <li>You sharing a connection string in Slack. We can't fix that.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="sec-pad-sm" id="verify" style="border-top: 1px solid var(--line);">
    <div class="wrap">
      <div class="eyebrow">04 · Verify everything</div>
      <h2 class="s-title" style="max-width: 760px;">Don't trust this page. Trust the code.</h2>
      <div class="verify-grid s-content">
        <a class="card verify-card" href={`${SITE.repo}/blob/main/src-tauri/src/storage.rs`}>
          <div class="vc-eye">Source</div>
          <div class="vc-title">Read the encryption code</div>
          <div class="vc-meta">~300 lines of Rust. AES-GCM, Argon2id, machine fingerprint. No closed-source layer.</div>
        </a>
        <a class="card verify-card" href={`${SITE.repo}/blob/main/.github/workflows/release.yml`}>
          <div class="vc-eye">Build</div>
          <div class="vc-title">Read the release pipeline</div>
          <div class="vc-meta">Every installer is built by GitHub Actions from a public tag. Reproduce the build, compare hashes.</div>
        </a>
        <a class="card verify-card" href="/download#verify">
          <div class="vc-eye">Hashes</div>
          <div class="vc-title">Verify your download</div>
          <div class="vc-meta">SHA-256 published next to every installer. The one-liner per OS is on the download page.</div>
        </a>
        <a class="card verify-card" href={`${SITE.repo}/security/advisories`}>
          <div class="vc-eye">Report</div>
          <div class="vc-title">Disclose a vulnerability</div>
          <div class="vc-meta">GitHub Security Advisories. Private until fixed; public once a patch ships.</div>
        </a>
      </div>
    </div>
  </section>

</Layout>

<script>
  const card = document.querySelector<HTMLElement>('.vault-bytes-card');
  if (card && 'IntersectionObserver' in window) {
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          card.classList.add('printed');
          io.unobserve(card);
        }
      }
    }, { threshold: 0.25 });
    io.observe(card);
  } else if (card) {
    card.classList.add('printed');
  }
</script>

<style>
  .principles { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  @media (max-width: 1000px) { .principles { grid-template-columns: 1fr; } }
  .principle { padding: 28px; position: relative; }
  .principle h3 { margin-top: 14px; margin-bottom: 12px; font-size: 18px; }
  .principle p { font-size: 14.5px; color: var(--ink-2); line-height: 1.6; }
  .p-num { font-size: 11px; letter-spacing: 0.14em; color: var(--ink-4); }

  .layers { display: grid; grid-template-columns: 1fr; gap: 0; border-top: 1px solid var(--line); }
  .layer {
    display: grid; grid-template-columns: 56px 220px 1fr; gap: 22px;
    align-items: start; padding: 20px 0;
    border-bottom: 1px solid var(--line);
  }
  @media (max-width: 800px) {
    .layer { grid-template-columns: 56px 1fr; }
    .l-detail { grid-column: 2 / 3; padding-top: 6px; }
  }
  .l-i { color: var(--ink-4); font-size: 12px; }
  .l-name { font-weight: 500; color: var(--ink); font-size: 15px; }
  .l-detail { color: var(--ink-2); font-size: 14px; line-height: 1.6; }

  .threats { display: grid; grid-template-columns: 1fr; gap: 0; border-top: 1px solid var(--line); }
  .threat {
    display: grid; grid-template-columns: 1fr 1.4fr; gap: 32px;
    padding: 22px 0; border-bottom: 1px solid var(--line);
  }
  @media (max-width: 800px) { .threat { grid-template-columns: 1fr; gap: 8px; } }
  .t-actor {
    font-family: var(--mono); font-size: 13.5px; color: var(--ink-2);
    display: flex; gap: 10px;
  }
  .t-bullet { color: var(--warn); }
  .t-defense { color: var(--ink-2); font-size: 14.5px; line-height: 1.55; }

  .limits ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; }
  .limits li { font-size: 14px; line-height: 1.55; color: var(--ink-2); padding-left: 18px; position: relative; }
  .limits li::before {
    content: '—'; position: absolute; left: 0; color: var(--ink-4);
  }
  .limits { padding: 24px 28px; }
  .limits em { color: var(--ink); font-style: normal; }

  .verify-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 18px; }
  @media (max-width: 800px) { .verify-grid { grid-template-columns: 1fr; } }
  .verify-card {
    padding: 24px 28px; transition: border-color .15s, background .15s;
    display: block; color: inherit;
  }
  .verify-card:hover { border-color: var(--line-2); background: var(--bg-2); }
  .vc-eye {
    font-family: var(--mono); font-size: 11px; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--ink-3); margin-bottom: 8px;
  }
  .vc-title { font-size: 16px; color: var(--ink); font-weight: 500; margin-bottom: 8px; }
  .vc-meta  { font-size: 13.5px; color: var(--ink-3); line-height: 1.55; }

  .src-link { color: var(--accent); border-bottom: 1px solid color-mix(in oklch, var(--accent) 40%, transparent); }
  .src-link:hover { color: var(--accent-w); }

  /* ========== Vault bytes (plaintext → ciphertext visual) ========== */
  .vault-bytes-card {
    display: grid;
    grid-template-columns: 1fr auto 1.25fr;
    gap: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 0%,
        color-mix(in oklch, var(--accent) 7%, transparent),
        transparent 70%),
      linear-gradient(180deg,
        color-mix(in oklch, var(--bg-1) 100%, transparent) 0%,
        color-mix(in oklch, var(--bg-2) 50%, transparent) 100%);
    border: 1px solid var(--line-1);
    border-radius: var(--r-3);
    box-shadow: var(--sh-1);
    overflow: hidden;
    margin-top: 36px;
  }
  .vb-side {
    padding: 28px 30px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .vb-side-out { background: color-mix(in oklch, var(--bg-0) 30%, transparent); }
  .vb-eye {
    font-size: 10.5px;
    color: var(--ink-4);
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .vb-side-in .vb-eye::before  { content: ''; }
  .vb-plain {
    margin: 0;
    font-size: 13px;
    line-height: 1.85;
    color: var(--ink-1);
    white-space: pre;
    background: transparent;
    border: 0;
    padding: 0;
  }
  .vbp-k  { color: var(--ink-1); }
  .vbp-eq { color: var(--ink-4); padding: 0 6px; }
  .vbp-v  { color: var(--accent); }
  .vb-foot {
    margin-top: auto;
    font-size: 10.5px;
    color: var(--ink-4);
    letter-spacing: 0.04em;
  }

  .vb-sep {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0 4px;
    position: relative;
  }
  .vb-sep-line {
    width: 1px;
    flex: 1;
    background: linear-gradient(180deg,
      transparent 0%,
      color-mix(in oklch, var(--accent) 35%, var(--line-2)) 50%,
      transparent 100%);
  }
  .vb-sep-chip {
    font-size: 10.5px;
    color: var(--ink-1);
    letter-spacing: 0.06em;
    padding: 8px 14px;
    margin: 12px 0;
    background: var(--bg-1);
    border: 1px solid color-mix(in oklch, var(--accent) 30%, var(--line-2));
    border-radius: 999px;
    white-space: nowrap;
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    box-shadow: 0 0 0 4px color-mix(in oklch, var(--bg-0) 60%, transparent);
  }
  .vb-sep-chip strong {
    color: var(--accent);
    font-weight: 500;
  }

  .vault-dump {
    font-family: var(--mono);
    font-size: 12px;
    line-height: 1.65;
    background:
      linear-gradient(180deg,
        color-mix(in oklch, var(--bg-0) 50%, transparent) 0%,
        color-mix(in oklch, var(--bg-0) 70%, transparent) 100%);
    border: 1px solid color-mix(in oklch, var(--line-1) 70%, transparent);
    border-radius: var(--r-2);
    padding: 14px 16px;
  }
  .vd-row {
    display: grid;
    grid-template-columns: 44px repeat(8, 1fr);
    gap: 6px;
    align-items: baseline;
    opacity: 0;
    transform: translateY(2px);
    transition: opacity 240ms var(--ease), transform 240ms var(--ease);
    transition-delay: calc(var(--i, 0) * 50ms);
  }
  .vault-bytes-card.printed .vd-row { opacity: 1; transform: none; }
  .vd-ofs {
    color: var(--ink-4);
    font-size: 10.5px;
    letter-spacing: 0.04em;
  }
  .vd-b {
    text-align: center;
    font-size: 12px;
    letter-spacing: 0.02em;
    color: var(--ink-3);
    border-radius: 2px;
    padding: 1px 2px;
    transition: color var(--t-med) var(--ease), background var(--t-med) var(--ease);
  }
  .vd-magic  { color: var(--ink-0); background: color-mix(in oklch, var(--ink-2) 12%, transparent); }
  .vd-salt   { color: oklch(0.82 0.12 78); background: color-mix(in oklch, oklch(0.82 0.12 78) 10%, transparent); }
  .vd-nonce  { color: var(--accent);       background: color-mix(in oklch, var(--accent) 10%, transparent); }
  .vd-cipher { color: var(--ink-4); }
  .vd-tag    { color: oklch(0.80 0.13 295); background: color-mix(in oklch, oklch(0.80 0.13 295) 10%, transparent); }

  .vault-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-top: 4px;
    font-size: 10.5px;
    color: var(--ink-3);
    letter-spacing: 0.04em;
  }
  .vl-item { display: inline-flex; align-items: center; gap: 6px; }
  .vl-sw {
    width: 10px; height: 10px;
    border-radius: 2px;
    border: 1px solid color-mix(in oklch, var(--line-2) 70%, transparent);
  }
  .vd-magic-bg  { background: color-mix(in oklch, var(--ink-1) 60%, transparent); }
  .vd-salt-bg   { background: oklch(0.82 0.12 78); }
  .vd-nonce-bg  { background: var(--accent); }
  .vd-cipher-bg { background: color-mix(in oklch, var(--ink-4) 80%, transparent); }
  .vd-tag-bg    { background: oklch(0.80 0.13 295); }

  .vault-bytes-caption {
    margin-top: 20px;
    font-size: 11.5px;
    line-height: 1.6;
    color: var(--ink-4);
    max-width: 760px;
  }
  .vault-layers-eyebrow {
    margin-top: 64px;
    font-size: 10.5px;
    color: var(--ink-3);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--line-1);
  }
  .vault-layers-eyebrow + .layers { border-top: 0; }

  @media (max-width: 1000px) {
    .vault-bytes-card { grid-template-columns: 1fr; }
    .vb-sep { flex-direction: row; padding: 4px 0; }
    .vb-sep-line { width: auto; height: 1px; flex: 1; background:
      linear-gradient(90deg,
        transparent 0%,
        color-mix(in oklch, var(--accent) 35%, var(--line-2)) 50%,
        transparent 100%); }
    .vb-sep-chip { writing-mode: horizontal-tb; transform: none; margin: 0 12px; }
    .vb-side { padding: 24px 22px; }
  }
  @media (max-width: 560px) {
    .vd-row { grid-template-columns: 36px repeat(8, 1fr); gap: 3px; }
    .vd-b { font-size: 11px; }
    .vd-ofs { font-size: 10px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .vd-row { opacity: 1; transform: none; transition: none; }
  }
</style>
